<!-- Hyper Term product shell. This native view is trusted application code.
     Agent-authored content enters later as versioned Block data, never markup. -->
<template name="agent-thread">
  <column min-width="400" grow="1" background="surface" label="Agent conversation">
    <row gap="6" padding="5" cross="center">
      <icon name="circle-dot" width="12" height="12" foreground="accent" />
      <text grow="1"><span weight="medium">Agent</span></text>
      <badge variant="secondary">{activeAgentProviderLabel}</badge>
      <badge variant="secondary">{agentConnectionLabel}</badge>
      <if test="{canOpenAgentEditor}">
        <button size="sm" variant="outline" icon="edit" on-press="open_agent_editor" label="Open ACP artifact editor">Edit</button>
      </if>
    </row>
    <separator />
    <!-- The Zig root replaces this labelled slot with a variable-height,
         tail-anchored virtual list. The unreachable branch keeps the Native
         model contract checking the builder-owned block vocabulary. -->
    <column grow="1" label="Agent blocks">
      <if test="false">
        <scroll grow="1" label="Agent block contract">
          <column gap="3" padding="10">
        <if test="{hasAgentBlocks}">
          <for each="agentBlocks" key="id" as="block">
            <if test="{block.isMessage}">
              <if test="{block.isUserMessage}">
                <row>
                  <spacer grow="1" />
                  <bubble>
                    <column gap="4" padding="9">
                      <text wrap="true">{block.content}</text>
                      <if test="{block.truncated}">
                        <text foreground="warning">Block clipped to 8 KiB in this view.</text>
                      </if>
                    </column>
                  </bubble>
                </row>
              </if>
              <else>
                <column gap="4" padding="2">
                  <column padding="2">
                    <markdown source="{block.content}" />
                  </column>
                  <if test="{block.truncated}">
                    <text foreground="warning">Response clipped to 8 KiB in this view.</text>
                  </if>
                </column>
              </else>
            </if>
            <else>
              <if test="{block.isActivity}">
                <accordion size="sm" text="{block.activityTitle}" selected="{block.expanded}" on-toggle="toggle_agent_block:{block.id}">
                  <column gap="5" padding="7">
                    <text foreground="text_muted">{block.activityMeta}</text>
                    <if test="{block.hasActivityDetails}">
                      <markdown source="{block.content}" />
                    </if>
                    <if test="{block.truncated}">
                      <text foreground="warning">Tool details clipped to 8 KiB in this view.</text>
                    </if>
                  </column>
                </accordion>
              </if>
              <else>
                <if test="{block.isOperation}">
                  <row gap="7" padding="5" cross="center">
                    <icon name="wrench" width="13" height="13" foreground="info" />
                    <text grow="1"><span weight="medium">{block.content}</span></text>
                    <text foreground="text_muted">{block.operationKindLabel} · {block.riskLabel}</text>
                    <badge variant="secondary">{block.stateLabel}</badge>
                  </row>
                </if>
                <else>
                  <card border-color="warning">
                    <column gap="9" padding="10">
                      <row gap="7" cross="center">
                        <icon name="alert" width="14" height="14" foreground="warning" />
                        <text grow="1"><span weight="medium">{block.approvalTitle}</span></text>
                      </row>
                      <text wrap="true" foreground="text_muted">{block.operationKindLabel} · {block.riskLabel}</text>
                      <text wrap="true">{block.content}</text>
                      <if test="{block.isApprovalPending}">
                        <if test="{block.canAllowOnce}">
                          <alert text="Brokered MCP tool">
                            <column gap="7" padding="9">
                              <text wrap="true">This read-only tool runs through the Rust permission broker and records a receipt.</text>
                              <column gap="7">
                                <button size="sm" variant="primary" on-press="allow_agent_effect:{block.operationId}" disabled="{agentPermissionBusy}">Allow once</button>
                                <button size="sm" variant="destructive" on-press="reject_agent_effect:{block.operationId}" disabled="{agentPermissionBusy}">Reject</button>
                                <button size="sm" variant="outline" on-press="cancel_agent_effect:{block.operationId}" disabled="{agentPermissionBusy}">Cancel request</button>
                              </column>
                            </column>
                          </alert>
                        </if>
                        <else>
                          <alert text="Proposal-only safety gate">
                            <column gap="7" padding="9">
                              <text wrap="true">Allow is unavailable until the Rust sandbox can enforce this exact effect.</text>
                              <column gap="7">
                                <button size="sm" variant="destructive" on-press="reject_agent_effect:{block.operationId}" disabled="{agentPermissionBusy}">Reject</button>
                                <button size="sm" variant="outline" on-press="cancel_agent_effect:{block.operationId}" disabled="{agentPermissionBusy}">Cancel request</button>
                              </column>
                            </column>
                          </alert>
                        </else>
                      </if>
                      <else>
                        <text foreground="text_muted">Decision: {block.decisionLabel}</text>
                      </else>
                    </column>
                  </card>
                </else>
              </else>
            </else>
          </for>
          <if test="{agent_history_clipped}">
            <text foreground="text_muted">Showing the latest 16 Agent blocks.</text>
          </if>
        </if>
        <else>
          <spacer height="4" />
        </else>
          </column>
        </scroll>
      </if>
    </column>
    <separator />
    <column padding="6">
      <input-group label="Agent prompt composer" height="{agentComposerHeight}">
        <textarea size="sm" text="{agentComposerText}" placeholder="Ask this Agent about the workspace" on-input="agent_composer_changed" on-submit="send_agent_prompt" disabled="{agentComposerDisabled}" label="Agent prompt" />
        <input-group-actions>
          <if test="{agent_command_count > 0}">
            <stack>
              <button size="sm" variant="ghost" icon="plus" on-press="toggle_agent_command_picker" disabled="{agentCapabilityBusy}" label="Agent commands"></button>
              <if test="{agent_command_picker_open}">
                <dropdown-menu anchor="above" anchor-alignment="start" on-dismiss="dismiss_agent_command_picker" label="Agent commands">
                  <for each="agentCommands" key="index" as="command">
                    <menu-item on-press="insert_agent_command:{command.index}">{command.menuLabel}</menu-item>
                  </for>
                </dropdown-menu>
              </if>
            </stack>
          </if>
          <for each="agentConfigOptions" key="id" as="option">
            <stack>
              <select size="sm" on-press="toggle_agent_config_picker:{option.index}" disabled="{agentCapabilityBusy}" label="{option.name}">{option.currentLabel}</select>
              <if test="{option.picker_open}">
                <dropdown-menu anchor="above" anchor-alignment="start" on-dismiss="dismiss_agent_config_picker" label="{option.name}">
                  <for each="openAgentConfigChoices" key="action_id" as="choice">
                    <menu-item selected="{choice.selected}" on-press="choose_agent_config:{choice.action_id}">{choice.name}</menu-item>
                  </for>
                </dropdown-menu>
              </if>
            </stack>
          </for>
          <spacer grow="1" />
          <button icon="send" size="icon" on-press="send_agent_prompt" disabled="{agentComposerDisabled}" label="Send prompt"></button>
        </input-group-actions>
      </input-group>
    </column>
    <if test="{hasAgentStatusNotice}">
      <status-bar>{agentStatus}</status-bar>
    </if>
  </column>
</template>

<template name="agent-editor">
  <column min-width="360" grow="1" background="background" label="ACP artifact editor">
    <row gap="8" padding="9" cross="center" background="surface_subtle">
      <icon name="edit" width="13" height="13" foreground="accent" />
      <text grow="1"><span weight="medium">Edit</span></text>
      <text foreground="text_muted"><span mono="true">{genUiArtifactLabel}</span></text>
      <badge variant="secondary">draft</badge>
      <button size="icon" variant="ghost" icon="x" on-press="close_agent_editor" label="Close ACP artifact editor"></button>
    </row>
    <separator />
    <column grow="1" background="background" label="Agent artifact editor viewport"></column>
  </column>
</template>

<column background="background">
  <row gap="8" padding="8" height="{titlebar_height}" cross="center" background="surface" window-drag="true" label="Session bar">
    <spacer width="{chrome_leading}" />
    <row gap="7" cross="center" grow="1">
      <icon name="terminal" width="15" height="15" foreground="accent" />
      <text><span weight="medium">Hyper Term</span></text>
      <separator height="16" />
      <row gap="4" grow="1" cross="center" label="Open sessions">
        <for each="openSessions" key="id" as="session">
          <button-group gap="0" label="{session.tabGroupLabel}">
            <button size="sm" variant="ghost" icon="{session.icon}" selected="{session.id == active_session_id}" on-press="select_session:{session.id}">
              {session.title} {session.id}
              <context-menu>
                <menu-item on-press="close_session:{session.id}">Close Tab</menu-item>
              </context-menu>
            </button>
            <button size="sm" variant="ghost" icon="x" selected="{session.id == active_session_id}" on-press="close_session:{session.id}" label="{session.closeLabel}"></button>
          </button-group>
        </for>
      </row>
    </row>
    <row gap="4" cross="center" label="New session">
      <button size="sm" variant="outline" icon="plus" on-press="choose_terminal" label="New Terminal tab">Terminal</button>
      <stack>
        <button-group gap="0" label="New Agent session">
          <button size="sm" variant="outline" icon="circle-dot" on-press="choose_agent" label="New Agent tab">Agent</button>
          <button size="sm" variant="outline" icon="chevron-down" on-press="toggle_agent_provider_picker" disabled="{agentProviderUnavailable}" label="Choose provider for a new Agent tab"></button>
        </button-group>
        <if test="{agent_provider_picker_open}">
          <dropdown-menu anchor="below" anchor-alignment="end" anchor-offset="12" on-dismiss="dismiss_agent_provider_picker">
            <if test="{codexProviderAvailable}">
              <menu-item selected="{selected_agent_provider == 'codex'}" disabled="{codexProviderDisabled}" on-press="choose_codex_agent">{codexProviderMenuLabel}</menu-item>
            </if>
            <if test="{codexAcpProviderAvailable}">
              <menu-item selected="{selected_agent_provider == 'codex_acp'}" disabled="{codexAcpProviderDisabled}" on-press="choose_codex_acp_agent">{codexAcpProviderMenuLabel}</menu-item>
            </if>
            <if test="{claudeAcpProviderAvailable}">
              <menu-item selected="{selected_agent_provider == 'claude_acp'}" disabled="{claudeAcpProviderDisabled}" on-press="choose_claude_acp_agent">{claudeAcpProviderMenuLabel}</menu-item>
            </if>
            <if test="{copilotAcpProviderAvailable}">
              <menu-item selected="{selected_agent_provider == 'copilot_acp'}" disabled="{copilotAcpProviderDisabled}" on-press="choose_copilot_acp_agent">{copilotAcpProviderMenuLabel}</menu-item>
            </if>
          </dropdown-menu>
        </if>
      </stack>
    </row>
    <spacer width="{chrome_trailing}" />
  </row>
  <separator />

  <if test="{isTerminal}">
    <column grow="1" background="background" label="Terminal session">
      <column grow="1" background="background" label="Terminal viewport">
        <if test="{terminalDisconnected}">
          <column gap="5" padding="16">
          <text foreground="text_muted"><span mono="true">Last login: Fri Jul 18 on ttys001</span></text>
          <text><span mono="true" foreground="accent">phodal@mac</span> <span mono="true" foreground="text_muted">~/ai/hyper-term</span> <span mono="true">%</span></text>
          <text foreground="text_muted"><span mono="true"># Start hyperd with the local terminal gateway to attach this session.</span></text>
          <text><span mono="true" foreground="accent">phodal@mac</span> <span mono="true" foreground="text_muted">~/ai/hyper-term</span> <span mono="true">%</span> <span mono="true" foreground="accent">_</span></text>
          </column>
        </if>
      </column>
      <status-bar>{terminalStatus}</status-bar>
    </column>
  </if>
  <else>
    <if test="{hasAgentEditor}">
      <split value="{agent_split}" on-resize="agent_split_resized" resize-duration="120" resize-easing="standard" grow="1">
        <use template="agent-thread" />
        <use template="agent-editor" />
      </split>
    </if>
    <else>
      <use template="agent-thread" />
    </else>
  </else>
</column>
