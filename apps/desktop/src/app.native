<!-- Hyper Term product shell. This native view is trusted application code.
     Agent-authored content enters later as versioned Block data, never markup. -->
<template name="agent-composer">
  <column padding="4">
    <input-group label="Agent prompt composer" height="{agentComposerHeight}">
      <textarea size="sm" text="{agentComposerText}" placeholder="Ask, use /commands, or mention a $skill" on-input="agent_composer_changed" on-submit="send_agent_prompt" disabled="{agentComposerInputDisabled}" autofocus="{agentComposerAutofocus}" label="Agent prompt" />
      <input-group-actions>
        <if test="{agent_command_count > 0}">
          <stack>
            <button size="sm" variant="ghost" icon="plus" on-press="toggle_agent_command_picker" disabled="{agentCapabilityBusy}" label="Agent commands"></button>
            <if test="{agent_command_picker_open}">
              <dropdown-menu anchor="above" anchor-alignment="start" width="420" on-dismiss="dismiss_agent_command_picker" label="Agent commands">
                <for each="agentCommands" key="index" as="command">
                  <menu-item on-press="insert_agent_command:{command.index}">{command.menuLabel}</menu-item>
                </for>
              </dropdown-menu>
            </if>
          </stack>
        </if>
        <spacer grow="1" />
        <for each="agentConfigOptions" key="id" as="option">
          <stack>
            <select size="sm" width="{option.compactWidth}" on-press="toggle_agent_config_picker:{option.index}" disabled="{agentCapabilityBusy}" label="{option.name}">{option.currentLabel}</select>
            <if test="{option.picker_open}">
              <dropdown-menu anchor="above" anchor-alignment="end" width="280" on-dismiss="dismiss_agent_config_picker" label="{option.name}">
                <for each="openAgentConfigChoices" key="action_id" as="choice">
                  <menu-item selected="{choice.selected}" on-press="choose_agent_config:{choice.action_id}">{choice.name}</menu-item>
                </for>
              </dropdown-menu>
            </if>
          </stack>
        </for>
        <if test="{hasAgentContextUsage}">
          <badge variant="secondary" label="Agent context usage">{agentContextUsage}</badge>
        </if>
        <if test="{hasAgentComposerStatus}">
          <row gap="5" cross="center" label="Agent turn status">
            <icon name="circle-dot" width="11" height="11" foreground="accent" />
            <text foreground="text_muted">{agentComposerStatus}</text>
          </row>
        </if>
        <if test="{hasAgentStopControl}">
          <button icon="pause" size="icon" variant="outline" on-press="cancel_agent_turn" disabled="{agentCancelDisabled}" label="Stop Agent turn"></button>
        </if>
        <else>
          <button icon="send" size="icon" on-press="send_agent_prompt" disabled="{agentSubmitDisabled}" label="Send prompt"></button>
        </else>
      </input-group-actions>
    </input-group>
  </column>
</template>

<template name="agent-thread">
  <column min-width="320" grow="1" background="surface" label="Agent conversation">
    <if test="{hasAgentThreadToolbar}">
      <if test="{agentSearchOpen}">
        <row gap="6" padding="3" cross="center" label="Agent history search">
          <search-field size="sm" grow="1" text="{agentSearchText}" placeholder="Search messages, tools, files, and approvals" on-input="agent_search_changed" autofocus="true" label="Search Agent history" />
          <if test="{hasAgentSearchQuery}">
            <text foreground="text_muted">{agentSearchResultCount} matches</text>
          </if>
          <button size="icon" variant="ghost" icon="x" on-press="close_agent_search" label="Close Agent history search"></button>
        </row>
      </if>
      <if test="{hasAgentThreadActions}">
        <row gap="5" padding="3" cross="center">
          <if test="{hasAgentRestoredHistory}">
            <row gap="5" cross="center" label="Recovered Agent history">
              <icon name="refresh-cw" width="11" height="11" foreground="text_muted" />
              <text foreground="text_muted">History restored</text>
            </row>
          </if>
          <if test="{hasAgentExecutionContext}">
            <button size="sm" variant="ghost" icon="circle-dot" on-press="toggle_agent_execution_context" label="Inspect Agent execution context">{agentExecutionContextSummary}</button>
          </if>
          <spacer grow="1" />
          <if test="{canOpenAgentEditor}">
            <button size="sm" variant="outline" icon="edit" on-press="open_agent_editor" label="Open ACP artifact editor">Edit</button>
          </if>
        </row>
      </if>
      <if test="{agent_execution_context_expanded}">
        <column gap="4" padding="6" background="surface_subtle" label="Agent execution context details">
          <for each="agentExecutionContexts" key="contextId" as="context">
            <column gap="2" padding="4">
              <row gap="7" cross="center">
                <text grow="1"><span mono="true">{context.contextId}</span></text>
                <badge variant="secondary">{context.modeLabel}</badge>
                <text foreground="text_muted"><span mono="true">{context.digestPrefix}</span></text>
              </row>
              <text foreground="text_muted">{context.binding_count} environment bindings · {context.credential_count} credential references</text>
            </column>
          </for>
        </column>
      </if>
      <separator />
    </if>
    <!-- Zig replaces this slot with the virtualized Agent timeline. Its
         builder vocabulary is contract-checked in agent_block_contract.native. -->
    <column grow="1" label="Agent blocks"></column>
    <separator />
    <if test="{hasAgentEditor}">
      <use template="agent-composer" />
    </if>
    <else>
      <column padding="8" label="Agent composer rail">
        <use template="agent-composer" />
      </column>
    </else>
    <if test="{hasAgentStatusNotice}">
      <status-bar>{agentStatus}</status-bar>
    </if>
  </column>
</template>

<template name="agent-editor">
  <column global-key="{genUiArtifactLabel}" min-width="360" grow="1" background="background" label="ACP artifact editor">
    <row gap="8" padding="9" cross="center" background="surface_subtle">
      <icon name="edit" width="13" height="13" foreground="accent" />
      <text grow="1"><span weight="medium">Edit</span></text>
      <text foreground="text_muted"><span mono="true">{genUiArtifactLabel}</span></text>
      <badge variant="secondary">draft</badge>
      <button size="icon" variant="ghost" icon="x" on-press="close_agent_editor" label="Close ACP artifact editor"></button>
    </row>
    <separator />
    <column grow="1" background="background" label="Agent artifact editor viewport"></column>
  </column>
</template>

<column background="background">
  <row gap="7" padding="6" height="{titlebar_height}" cross="center" background="surface" window-drag="true" label="Session bar">
    <spacer width="{chrome_leading}" />
    <row gap="7" cross="center" grow="1">
      <icon name="terminal" width="15" height="15" foreground="accent" />
      <text><span weight="medium">Hyper Term</span></text>
      <separator height="16" />
      <row gap="4" grow="1" cross="center" label="Open sessions"></row>
    </row>
    <row gap="4" cross="center" label="New session">
      <button size="sm" variant="outline" icon="plus" on-press="choose_terminal" disabled="{sessionLimitReached}" label="New Terminal tab">Terminal</button>
      <stack>
        <button-group gap="0" label="New Agent session">
          <button size="sm" variant="outline" icon="circle-dot" on-press="choose_agent" disabled="{sessionLimitReached}" label="New Agent tab">New Agent</button>
          <button size="sm" variant="outline" icon="chevron-down" on-press="toggle_agent_provider_picker" disabled="{agentProviderPickerUnavailable}" label="Choose provider for a new Agent tab"></button>
        </button-group>
        <if test="{agent_provider_picker_open}">
          <dropdown-menu anchor="below" anchor-alignment="end" anchor-offset="8" width="360" on-dismiss="dismiss_agent_provider_picker">
            <if test="{codexProviderAvailable}">
              <menu-item selected="{selected_agent_provider == 'codex'}" disabled="{codexProviderDisabled}" on-press="choose_codex_agent">{codexProviderMenuLabel}</menu-item>
            </if>
            <if test="{codexAcpProviderAvailable}">
              <menu-item selected="{selected_agent_provider == 'codex_acp'}" disabled="{codexAcpProviderDisabled}" on-press="choose_codex_acp_agent">{codexAcpProviderMenuLabel}</menu-item>
            </if>
            <if test="{claudeAcpProviderAvailable}">
              <menu-item selected="{selected_agent_provider == 'claude_acp'}" disabled="{claudeAcpProviderDisabled}" on-press="choose_claude_acp_agent">{claudeAcpProviderMenuLabel}</menu-item>
            </if>
            <if test="{copilotAcpProviderAvailable}">
              <menu-item selected="{selected_agent_provider == 'copilot_acp'}" disabled="{copilotAcpProviderDisabled}" on-press="choose_copilot_acp_agent">{copilotAcpProviderMenuLabel}</menu-item>
            </if>
            <if test="{hasProviderLoginActions}">
              <separator />
              <if test="{codexLoginRequired}">
                <menu-item icon="terminal" on-press="open_codex_login_terminal">Sign in to Codex in Terminal</menu-item>
              </if>
              <if test="{claudeLoginRequired}">
                <menu-item icon="terminal" on-press="open_claude_login_terminal">Sign in to Claude in Terminal</menu-item>
              </if>
            </if>
            <separator />
            <menu-item icon="refresh-cw" disabled="{agent_provider_refresh_in_flight}" on-press="refresh_agent_providers">{agentProviderRefreshLabel}</menu-item>
          </dropdown-menu>
        </if>
      </stack>
    </row>
    <spacer width="{chrome_trailing}" />
  </row>
  <separator />

  <if test="{isTerminal}">
    <column grow="1" background="background" label="Terminal session">
      <if test="{hasProviderLoginHint}">
        <row gap="8" padding="8" cross="center" background="surface_subtle" label="Provider sign-in guide">
          <icon name="terminal" width="14" height="14" foreground="accent" />
          <column gap="2" grow="1">
            <text><span weight="medium">{providerLoginLabel}</span> <span mono="true">{providerLoginCommand}</span></text>
            <text foreground="text_muted">{providerLoginStatus}</text>
          </column>
          <button size="sm" variant="outline" on-press="copy_provider_login_command" disabled="{providerLoginCopyInFlight}" label="Copy provider sign-in command">Copy</button>
          <button size="sm" variant="outline" icon="refresh-cw" on-press="refresh_agent_providers" disabled="{agent_provider_refresh_in_flight}" label="Refresh Agent providers">Refresh</button>
          <button size="icon" variant="ghost" icon="x" on-press="dismiss_provider_login_hint" label="Dismiss provider sign-in guide"></button>
        </row>
        <separator />
      </if>
      <column grow="1" background="background" label="Terminal viewport">
        <if test="{terminalDisconnected}">
          <column gap="5" padding="16">
          <text foreground="text_muted"><span mono="true">Last login: Fri Jul 18 on ttys001</span></text>
          <text><span mono="true" foreground="accent">phodal@mac</span> <span mono="true" foreground="text_muted">~/ai/hyper-term</span> <span mono="true">%</span></text>
          <text foreground="text_muted"><span mono="true"># Start hyperd with the local terminal gateway to attach this session.</span></text>
          <text><span mono="true" foreground="accent">phodal@mac</span> <span mono="true" foreground="text_muted">~/ai/hyper-term</span> <span mono="true">%</span> <span mono="true" foreground="accent">_</span></text>
          </column>
        </if>
      </column>
      <status-bar>{terminalStatus}</status-bar>
    </column>
  </if>
  <else>
    <if test="{isCapsule}">
      <column grow="1" background="background" label="Offline Bug Capsule">
        <row gap="7" padding="7" cross="center" background="surface_subtle">
          <icon name="circle-dot" width="13" height="13" foreground="accent" />
          <text grow="1"><span weight="medium">Offline Bug Capsule</span></text>
          <badge variant="secondary">replay only</badge>
          <badge variant="secondary">Rust verified</badge>
        </row>
        <separator />
        <column grow="1" background="background" label="Agent artifact editor viewport"></column>
      </column>
    </if>
    <else>
      <if test="{hasAgentEditor}">
        <split value="{agent_split}" on-resize="agent_split_resized" resize-duration="120" resize-easing="standard" grow="1">
          <use template="agent-thread" />
          <use template="agent-editor" />
        </split>
      </if>
      <else>
        <use template="agent-thread" />
      </else>
    </else>
  </else>
</column>
