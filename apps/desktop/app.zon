.{
    .id = "dev.hyperterm.desktop",
    .name = "hyper-term",
    .display_name = "Hyper Term",
    .description = "A terminal-first native shell for brokered AI workflows.",
    .version = "0.1.0",
    .icons = .{"assets/icon.png"},
    .platforms = .{"macos"},
    .permissions = .{ "view", "command", "network" },
    .capabilities = .{ "native_views", "gpu_surfaces", "webview", "menus", "shortcuts", "network" },
    .shortcuts = .{
        .{ .id = "hyper-term.new-terminal", .key = "t", .modifiers = .{"primary"} },
        .{ .id = "hyper-term.new-agent", .key = "n", .modifiers = .{ "primary", "shift" } },
        .{ .id = "hyper-term.close-session", .key = "w", .modifiers = .{"primary"} },
    },
    .menus = .{
        .{
            .title = "File",
            .items = .{
                .{ .label = "New Terminal Tab", .command = "hyper-term.new-terminal", .key = "t", .modifiers = .{"primary"} },
                .{ .label = "New Agent Tab", .command = "hyper-term.new-agent", .key = "n", .modifiers = .{ "primary", "shift" } },
                .{ .separator = true },
                .{ .label = "Close Tab", .command = "hyper-term.close-session", .key = "w", .modifiers = .{"primary"} },
            },
        },
        .{
            .title = "Agent",
            .items = .{
                .{ .label = "New Codex Agent Tab", .command = "hyper-term.new-codex-agent" },
                .{ .label = "New Codex ACP Agent Tab", .command = "hyper-term.new-codex-acp-agent" },
                .{ .label = "New Claude ACP Agent Tab", .command = "hyper-term.new-claude-acp-agent" },
            },
        },
    },
    .shell = .{
        .windows = .{
            .{
                .label = "main",
                .title = "Hyper Term",
                .width = 1180,
                .height = 760,
                .min_width = 840,
                .min_height = 520,
                .restore_state = true,
                .restore_policy = "clamp_to_visible_screen",
                .titlebar = "hidden_inset_tall",
                .views = .{
                    .{ .label = "hyper-term-canvas", .kind = "gpu_surface", .fill = true, .role = "Hyper Term canvas", .accessibility_label = "Hyper Term", .gpu_backend = "metal", .gpu_pixel_format = "bgra8_unorm", .gpu_present_mode = "timer", .gpu_alpha_mode = "opaque", .gpu_color_space = "srgb", .gpu_vsync = true },
                    .{ .label = "hyper-term-terminal-view", .kind = "webview", .parent = "hyper-term-canvas", .url = "zero://inline", .x = 0, .y = 0, .width = 1, .height = 1, .layer = 20 },
                    .{ .label = "hyper-term-genui-view", .kind = "webview", .parent = "hyper-term-canvas", .url = "zero://inline", .x = 0, .y = 0, .width = 1, .height = 1, .layer = 21 },
                },
            },
        },
    },
    .security = .{
        .navigation = .{
            .allowed_origins = .{ "zero://app", "zero://inline", "http://127.0.0.1:47437" },
            .external_links = .{ .action = "deny" },
        },
    },
    .web_engine = "system",
    .cef = .{ .dir = "third_party/cef/macos", .auto_install = false },
}
